        "n1": 2,
        "n2": 2,
        "x1": 1,
        "x2": 2,
        "rate1": 0.5,
        "rate2": 1.0
      },
      {
        "segment": "High",
        "contrib": -0.3333333333333333,
        "n1": 2,
        "n2": 2,
        "x1": 2,
        "x2": 0,
        "rate1": 1.0,
        "rate2": 0.0
      }
    ]
